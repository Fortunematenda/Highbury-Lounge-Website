# Highbury Lounge — environment

# Required for admin seed protection in production
SEED_KEY=change-me-in-production

# Session cookies: set "false" for plain HTTP (IP:port). Use "true" behind HTTPS.
COOKIE_SECURE=false

# Default admin created by POST /api/seed (dev only without SEED_KEY)
# Email: admin@highbury.com
# Password: HighburyAdmin123!

# Menu image uploads (Cloudflare R2 binding: UPLOADS)
# Max upload size in megabytes (client + server validated)
MAX_MENU_IMAGE_SIZE_MB=5
# Public URL prefix served by the Worker from R2 (see web/worker/index.ts)
PUBLIC_UPLOAD_BASE_URL=/uploads

# SMTP (optional — notifications are queued even when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Highbury Lounge <test@higbury.com>"

# Future payment gateway
# PAYMENT_PROVIDER=
# PAYMENT_SECRET_KEY=
